<%- include('partials/header.ejs') %>

<header class="hero-section">
    <div class="container">
        <h1 class="display-4 fw-bold">Chi Siamo - The Leagues</h1>
    </div>
</header>

<div class="container my-5">
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card card-custom shadow h-100">
        <div class="card-body">
          <h5 class="card-title fw-bold">⚽ Passione & Sviluppo</h5>
          <p class="card-text">
            The Leagues è un progetto personale nato con un doppio obiettivo:
            unire la passione per il calcio europeo e migliorare le competenze
            nello sviluppo web.
          </p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card card-custom shadow h-100">
        <div class="card-body">
          <h5 class="card-title fw-bold">📈 Dati & Classifiche</h5>
          <p class="card-text">
            Il sito si concentra sulla visualizzazione delle classifiche
            aggiornate dei principali campionati europei, con un'interfaccia
            semplice e immediata. Utilizzando le api
            https://www.football-data.org/
          </p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card card-custom shadow h-100">
        <div class="card-body">
          <h5 class="card-title fw-bold">⚙️ Evoluzione & Futuro</h5>
          <p class="card-text">
            Il progetto è in continua evoluzione, con future funzionalità extra
            come informazioni dettagliate sulle squadre e statistiche.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer.ejs') %>
