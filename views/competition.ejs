<%- include('partials/header.ejs') %>

<main>
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-xl-10">
        <p class="text-center text-muted mb-1 fs-6">
          Competition: <span class="fw-semibold"><%= locals.standHeader.competition.name %></span>
        </p>

        <div class="card standing-card">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th class="rank-col">#</th>
                  <th class="team-col">Squadra</th>
                  <th class="stat-col">PG</th>
                  <th class="stat-col">V</th>
                  <th class="stat-col">N</th>
                  <th class="stat-col">P</th>
                  <th class="stat-col points-col">PT</th>
                </tr>
              </thead>
              <tbody>
                <% locals.standRow.table.forEach(element => { %>
                    <tr>
                        <td class="rank-col"><%= element.position %></td>
                            <td class="team-col d-flex align-items-center">
                                <img
                                src="<%= element.team.crest %>"
                                class="team-logo-small"
                                alt="logo Team"
                                />                              
                                <span class="team-name"><%= element.team.shortName %></span>
                            </td>
                        <td class="stat-col"><%= element.playedGames %></td>
                        <td class="stat-col"><%= element.won %></td>
                        <td class="stat-col"><%= element.draw %></td>
                        <td class="stat-col"><%= element.lost %></td>
                        <td class="stat-col points-col text-primary"><%= element.points %></td>
                    </tr>
                <% }); %>                
              </tbody>
            </table>
          </div>
        </div>

        <div class="mt-4 d-flex gap-3 justify-content-center small text-muted">
          <span
            ><span class="badge bg-primary rounded-pill">&nbsp;</span> Champions
            League</span
          >
          <span
            ><span class="badge bg-danger rounded-pill">&nbsp;</span>
            Retrocessione</span
          >
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer.ejs') %>
